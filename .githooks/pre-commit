#!/usr/bin/env bash
# 启用方式（仓库根目录执行一次）：
#   git config core.hooksPath .githooks
# 跳过本次检查：git commit --no-verify

set -euo pipefail

REPO_ROOT=$(git rev-parse --show-toplevel)
cd "$REPO_ROOT"

STAGED=$(git diff --cached --name-only)

if ! python3 code/tools/check_one_control_guardrails.py --strict; then
  echo 'pre-commit: One-Control guardrail check failed. Fix architecture drift or use git commit --no-verify only for emergency work.' >&2
  exit 1
fi

need_sync_docs=0
if printf '%s\n' "$STAGED" | grep -qE '^scripts/(entrypoints|orchestration|lib)/.*\.sh$'; then
  need_sync_docs=1
fi
if printf '%s\n' "$STAGED" | grep -Fxq 'code/paths_config.py'; then
  need_sync_docs=1
fi

if [[ "$need_sync_docs" -eq 0 ]]; then
  exit 0
fi

DOC='docs/ODCR_Scripts_and_Runtime_Guide.md'
if ! printf '%s\n' "$STAGED" | grep -Fxq "$DOC"; then
  echo 'pre-commit: 检测到已暂存对 scripts/entrypoints|orchestration|lib/*.sh 或 code/paths_config.py 的修改，须在同一提交中同步暂存：' >&2
  echo "  - $DOC" >&2
  echo '（若本次改动不影响文档内容，可仍暂存文档并做一次无实质修改的保存，或改用 git commit --no-verify 跳过。）' >&2
  exit 1
fi

exit 0
