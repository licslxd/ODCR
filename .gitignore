# Dataset artifacts are local evidence contracts.
data/*
merged/*

# Keep directory sentinels.
!AI_analysis/.gitkeep
!data/.gitkeep
!merged/.gitkeep

# Local editor/system
.vscode/
.idea/
.DS_Store

# Root-level scheduler flag fragments sometimes produced by failed copy/paste.
--gres=*
--wrap=*
-J
