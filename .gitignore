# Large local model artifacts
artifacts/models/

# Python caches
__pycache__/
*.py[cod]
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/

# Local secrets / credentials
.env
.env.*
*.pem
*.key
*.crt
*.p12
*.pfx
.netrc
id_rsa
id_ed25519

# Local runtime artifacts
runs/
cache/
test_artifacts/
test/
test/*.log
*.log
slurm-*.out
AI_analysis/01_raw_logs/
AI_analysis/02_search_hits/
AI_analysis/03_evidence_ledgers/
AI_analysis/04_phase_summaries/
AI_analysis/05_final_reports/
